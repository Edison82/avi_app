generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  OPERARIO
  CONDUCTOR
}

enum CategoriaHuevo {
  JUMBO
  AAA
  AA
  A
  B
  C
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

model Usuario {
  id            String               @id @default(uuid())
  nombre        String
  email         String               @unique
  password      String
  rol           Rol                  @default(ADMIN)
  activo        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  configuracion ConfiguracionGranja?

  granja          Granja?   @relation("GranjaAdmin")
  creadoPorId     String?
  creadoPor       Usuario?  @relation("UsuariosCreados", fields: [creadoPorId], references: [id])
  usuariosCreados Usuario[] @relation("UsuariosCreados")

  registros   RegistroDiario[]
  entregas    EntregaConductor[]
  granjas     UsuarioGranja[]
  cargas      CargaConductor[]
  movimientos MovimientoInsumo[]
  permisos    PermisoOperario[]

  @@map("usuarios")
}

model Granja {
  id           String   @id @default(uuid())
  nombre       String
  slug         String   @unique
  numeroAves   Int
  fechaIngreso DateTime @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  adminId String  @unique
  admin   Usuario @relation("GranjaAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  registros  RegistroDiario[]
  entregas   EntregaConductor[]
  categorias Categoria[]
  usuarios   UsuarioGranja[]
  inventario InventarioHuevos[]
  cargas     CargaConductor[]
  insumos    InsumoInventario[]
  permisos   PermisoOperario[]

  @@map("granjas")
}

model Categoria {
  id          String        @id @default(uuid())
  nombre      String
  descripcion String?
  activa      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  granjaId    String
  granja      Granja        @relation(fields: [granjaId], references: [id], onDelete: Cascade)
  gastos      GastoDiario[]

  @@unique([granjaId, nombre])
  @@map("categorias")
}

model ConfiguracionGranja {
  id             String   @id @default(uuid())
  nombreGranja   String
  numeroGallinas Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  usuarioId      String   @unique
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("configuracion_granja")
}

model RegistroDiario {
  id                  String         @id @default(uuid())
  fecha               DateTime       @db.Date
  huevosProducidos    Int
  huevosVendidos      Int
  precioVentaUnitario Decimal        @db.Decimal(10, 2)
  ingresoTotal        Decimal        @db.Decimal(10, 2)
  observaciones       String?
  mortalidad          Int            @default(0)
  categoriaHuevo      CategoriaHuevo @default(A)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  granjaId  String
  granja    Granja        @relation(fields: [granjaId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  gastos    GastoDiario[]

  @@unique([granjaId, fecha])
  @@index([granjaId, fecha])
  @@map("registros_diarios")
}

model GastoDiario {
  id          String         @id @default(uuid())
  descripcion String
  monto       Decimal        @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())
  categoriaId String
  registroId  String
  categoria   Categoria      @relation(fields: [categoriaId], references: [id])
  registro    RegistroDiario @relation(fields: [registroId], references: [id], onDelete: Cascade)

  @@index([registroId])
  @@map("gastos_diarios")
}

model EntregaConductor {
  id                  String   @id @default(uuid())
  fecha               DateTime @db.Date
  huevosEntregados    Int      // total sumado de todas las categorías
  precioVentaUnitario Decimal  @db.Decimal(10, 2)
  ingresoTotal        Decimal  @db.Decimal(10, 2)
  clienteNombre       String?
  observaciones       String?

  // Detalle de huevos por categoría — JSON array:
  // [{ categoria: "AAA", cantidad: 60 }, { categoria: "A", cantidad: 90 }]
  // @default([]) garantiza compatibilidad con entregas anteriores
  detalleCategoriasJson Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  granjaId    String
  granja      Granja  @relation(fields: [granjaId], references: [id], onDelete: Cascade)
  conductorId String
  conductor   Usuario @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([granjaId, fecha])
  @@map("entregas_conductor")
}

model InventarioHuevos {
  id             String         @id @default(uuid())
  categoriaHuevo CategoriaHuevo
  cantidadHuevos Int            @default(0)
  updatedAt      DateTime       @updatedAt

  granjaId String
  granja   Granja @relation(fields: [granjaId], references: [id], onDelete: Cascade)

  @@unique([granjaId, categoriaHuevo])
  @@map("inventario_huevos")
}

model CargaConductor {
  id                 String         @id @default(uuid())
  fecha              DateTime       @default(now())
  categoriaHuevo     CategoriaHuevo
  cubetas            Int
  huevosEquivalentes Int
  observaciones      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  granjaId    String
  granja      Granja  @relation(fields: [granjaId], references: [id], onDelete: Cascade)
  conductorId String
  conductor   Usuario @relation(fields: [conductorId], references: [id], onDelete: Cascade)

  @@index([granjaId, fecha])
  @@map("cargas_conductor")
}

model InsumoInventario {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  unidad      String   @default("unidad")
  stockActual Decimal  @default(0) @db.Decimal(10, 2)
  stockMinimo Decimal  @default(0) @db.Decimal(10, 2)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  granjaId    String
  granja      Granja             @relation(fields: [granjaId], references: [id], onDelete: Cascade)
  movimientos MovimientoInsumo[]

  @@unique([granjaId, nombre])
  @@index([granjaId])
  @@map("insumos_inventario")
}

model MovimientoInsumo {
  id             String         @id @default(uuid())
  tipo           TipoMovimiento
  cantidad       Decimal        @db.Decimal(10, 2)
  precioUnitario Decimal?       @db.Decimal(10, 2)
  observaciones  String?
  fecha          DateTime       @default(now())
  createdAt      DateTime       @default(now())

  insumoId  String
  insumo    InsumoInventario @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([insumoId, fecha])
  @@map("movimientos_insumo")
}

model PermisoOperario {
  id        String   @id @default(uuid())
  activo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  granjaId  String
  granja    Granja  @relation(fields: [granjaId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([granjaId, usuarioId])
  @@map("permisos_operario")
}

model UsuarioGranja {
  id        String   @id @default(uuid())
  usuarioId String
  granjaId  String
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  granja    Granja   @relation(fields: [granjaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, granjaId])
  @@map("usuarios_granjas")
}
